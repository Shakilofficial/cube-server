        {
          "name": "Update Profile (with Avatar Upload)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "{{accessToken}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Test User Updated",
                  "type": "text",
                  "description": "Optional: user display name"
                },
                {
                  "key": "phone",
                  "value": "+8801712345678",
                  "type": "text",
                  "description": "Optional: phone number"
                },
                {
                  "key": "avatar",
                  "type": "file",
                  "description": "Optional: avatar image file (JPEG, PNG, WebP, GIF, AVIF — max 5 MB). Server compresses to WebP and uploads to S3.",
                  "disabled": true
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/v1/users/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "v1",
                "users",
                "profile"
              ]
            },
            "description": "Update the authenticated user's profile.\n\n**Content-Type**: `multipart/form-data`\n\n| Field  | Type   | Required | Notes |\n|--------|--------|----------|-------|\n| name   | string | No       | 2–100 chars |\n| phone  | string | No       | max 20 chars |\n| avatar | file   | No       | JPEG/PNG/WebP/GIF/AVIF, max 5 MB. Compressed to WebP + uploaded to S3. Old avatar auto-deleted. |\n\nAt least one field must be present."
          },
          "response": []
        },

