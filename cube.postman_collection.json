          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const data = response.data || response;",
                  "if (data.userId) {",
                  "    pm.collectionVariables.set(\"userId\", data.userId);",
