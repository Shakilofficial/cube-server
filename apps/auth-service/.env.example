# Auth Service Environment Variables
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:secret@localhost:5432/auth_db?schema=public"

# JWT Secrets (minimum 32 chars in production, use random 64-char hex strings)
JWT_ACCESS_SECRET="change-me-to-a-64-char-random-hex-string-in-production-00000000"
JWT_REFRESH_SECRET="change-me-to-another-64-char-random-hex-string-in-prod-00000000"

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# Bcrypt
BCRYPT_ROUNDS=12

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
